{
  "name": "interview-pilot",
  "version": "1.0.0",
  "description": "Real-time AI Interview Assistant — Audio Transcription, AI Answers & Screen Capture",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.interviewpilot.app",
    "productName": "InterviewPilot",
    "directories": { "output": "dist" },
    "win": { "target": "nsis", "icon": "assets/icon.png" },
    "nsis": {
      "oneClick": true,
      "shortcutName": "InterviewPilot"
    },
    "files": [ "src/**/*", "assets/**/*" ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "author": "InterviewPilot",
  "license": "MIT"
}
